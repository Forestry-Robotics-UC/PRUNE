<launch>
  <arg name="use_sim_time" default="false"/>
  <arg name="play_bag" default="false"/>
  <arg name="bag_path" default=""/>
  <arg name="bag_path_extra" default=""/>
  <arg name="rate" default="1.0"/>
  <arg name="start_sec" default="0.0"/>
  <arg name="duration_sec" default=""/>
  <arg name="pause" default="false"/>
  <arg name="loop" default="false"/>
  <arg name="relay_bag_tf" default="true"/>
  <arg name="bag_tf_topic" default="/tf_bag"/>
  <arg name="bag_tf_static_topic" default="/tf_static_bag"/>
  <arg name="use_urdf" default="false"/>
  <arg name="urdf_path" default=""/>
  <arg name="rviz" default="false"/>
  <arg name="rviz_config" default=""/>
  <arg name="publish_localization_tf" default="false"/>
  <arg name="localization_topic" default="/localization"/>
  <arg name="localization_type" default="odom"/>
  <arg name="localization_parent_frame" default="odom"/>
  <arg name="localization_child_frame" default="base_link"/>
  <arg name="localization_stamp_source_topic" default=""/>
  <arg name="localization_stamp_source_type" default="image"/>
  <arg name="localization_stamp_source_max_age_sec" default="0.05"/>
  <!-- Tri-state: empty means do not override YAML; set to true/false to override. -->
  <arg name="debug" default=""/>
  <arg name="use_republish" default="false"/>
  <arg name="semantic_in_topic" default="/semantic/labels"/>
  <arg name="semantic_topic" default="/semantic/labels"/>
  <arg name="semantic_input_type" default=""/>
  <arg name="confidence_in_topic" default=""/>
  <arg name="confidence_topic" default=""/>
  <arg name="depth_input_in_topic" default=""/>
  <arg name="depth_input_topic" default="/camera/depth/image_rect_raw"/>
  <arg name="camera_info_txt" default=""/>
  <arg name="camera_frame" default=""/>
  <arg name="camera_info_topic" default=""/>
  <arg name="output_topic" default="semantic_pointcloud"/>
  <arg name="target_frame" default=""/>
  <arg name="dataset_config" default=""/>
  <arg name="projection_invalid_mask_topic" default=""/>
  <arg name="projection_invalid_mask_value" default=""/>
  <arg name="experiment_variant_name" default=""/>
  <arg name="bag_name" default=""/>
  <arg name="results_dir" default=""/>
  <arg name="enable_metrics_csv" default="false"/>
  <!-- Gate overrides: empty = use YAML value; set to true/false/numeric to override. -->
  <arg name="use_invalid_mask" default=""/>
  <arg name="use_depth_edge_rejection" default=""/>
  <arg name="use_occlusion_gate" default=""/>
  <arg name="use_geometric_gate" default=""/>
  <arg name="projection_patch_size" default=""/>
  <arg name="projection_confidence_min" default=""/>
  <arg name="projection_reject_depth_edges" default=""/>
  <arg name="projection_occlusion_epsilon_m" default=""/>
  <arg name="projection_occlusion_radius_px" default=""/>
  <arg name="projection_geometric_enable" default=""/>
  <arg name="geometric_curvature_max" default=""/>
  <arg name="geometric_up_labels" default=""/>
  <arg name="geometric_score_min" default=""/>
  <arg name="geometric_fold_into_confidence" default=""/>

  <param name="use_sim_time" value="$(arg use_sim_time)"/>

  <group if="$(arg play_bag)">
    <group if="$(arg relay_bag_tf)">
      <node pkg="topic_tools" type="relay" name="tf_bag_relay"
            args="$(arg bag_tf_topic) /tf"
            launch-prefix="bash -c 'sleep 2 &amp;&amp; exec $0 $@' --"/>
      <node pkg="topic_tools" type="relay" name="tf_static_bag_relay"
            args="$(arg bag_tf_static_topic) /tf_static"
            launch-prefix="bash -c 'sleep 2 &amp;&amp; exec $0 $@' --"/>
    </group>
    <!-- Four variants to avoid unsupported $(eval) in args attribute. -->
    <node if="$(eval arg('duration_sec') == '' and not arg('pause') and not arg('loop'))"
          pkg="rosbag" type="play" name="rosbag_play" output="screen" required="true"
          args="--clock --rate $(arg rate) --start $(arg start_sec) --delay 4.0
                $(arg bag_path) $(arg bag_path_extra)"/>
    <node if="$(eval arg('duration_sec') != '' and not arg('pause') and not arg('loop'))"
          pkg="rosbag" type="play" name="rosbag_play" output="screen" required="true"
          args="--clock --rate $(arg rate) --start $(arg start_sec) --duration $(arg duration_sec) --delay 4.0
                $(arg bag_path) $(arg bag_path_extra)"/>
    <node if="$(eval arg('duration_sec') == '' and arg('pause') and not arg('loop'))"
          pkg="rosbag" type="play" name="rosbag_play" output="screen"
          args="--clock --rate $(arg rate) --start $(arg start_sec) --pause --delay 4.0
                $(arg bag_path) $(arg bag_path_extra)"/>
    <node if="$(eval arg('duration_sec') != '' and arg('pause') and not arg('loop'))"
          pkg="rosbag" type="play" name="rosbag_play" output="screen"
          args="--clock --rate $(arg rate) --start $(arg start_sec) --duration $(arg duration_sec) --pause --delay 4.0
                $(arg bag_path) $(arg bag_path_extra)"/>
  </group>

  <group if="$(arg use_urdf)">
    <param name="robot_description" command="$(find xacro)/xacro '$(arg urdf_path)'" />
    <node pkg="robot_state_publisher" type="robot_state_publisher"
          name="robot_state_publisher" output="screen">
      <param name="publish_frequency" type="double" value="30.0"/>
    </node>
  </group>

  <group if="$(arg publish_localization_tf)">
    <node pkg="prune_ros" type="pose_to_tf.py" name="localization_to_tf" output="screen">
      <param name="pose_topic" value="$(arg localization_topic)"/>
      <param name="input_type" value="$(arg localization_type)"/>
      <param name="parent_frame" value="$(arg localization_parent_frame)"/>
      <param name="child_frame" value="$(arg localization_child_frame)"/>
      <param name="stamp_source_topic" value="$(arg localization_stamp_source_topic)"/>
      <param name="stamp_source_type" value="$(arg localization_stamp_source_type)"/>
      <param name="stamp_source_max_age_sec" value="$(arg localization_stamp_source_max_age_sec)"/>
    </node>
  </group>

  <group if="$(arg rviz)">
    <node pkg="rviz" type="rviz" name="prune_rviz"
          args="-d $(arg rviz_config)" output="screen"/>
  </group>

  <rosparam command="load"
            file="$(find prune_ros)/config/core.yaml"
            ns="prune_node"/>
  <rosparam command="load"
            file="$(find prune_ros)/config/expert.yaml"
            ns="prune_node"/>
  <rosparam command="load"
            file="$(arg dataset_config)"
            ns="prune_node"
            if="$(eval arg('dataset_config') != '')"/>

  <!-- Optional decompression via image_transport (semantic, confidence, depth) -->
  <group if="$(arg use_republish)">
    <node pkg="image_transport" type="republish" name="semantic_republish"
          args="compressed in:=$(arg semantic_in_topic) raw out:=$(arg semantic_topic)"/>
    <node pkg="image_transport" type="republish" name="depth_republish"
          if="$(eval arg('depth_input_in_topic') != '')"
          args="compressedDepth in:=$(arg depth_input_in_topic) raw out:=$(arg depth_input_topic)"/>
    <node pkg="image_transport" type="republish" name="confidence_republish"
          if="$(eval arg('confidence_in_topic') != '')"
          args="compressed in:=$(arg confidence_in_topic) raw out:=$(arg confidence_topic)"/>
  </group>

  <node pkg="prune_ros" type="prune_node.py" name="prune_node" output="screen"
        args="$(eval '_debug:=' + str(arg('debug')).lower() if str(arg('debug')) != '' else '')">
    <remap from="semantic_pointcloud" to="$(arg output_topic)"/>
    <param name="camera_info_txt" value="$(arg camera_info_txt)"
           if="$(eval arg('camera_info_txt') != '')"/>
    <param name="camera_frame" value="$(arg camera_frame)"
           if="$(eval arg('camera_frame') != '')"/>
    <param name="semantic_topic" value="$(arg semantic_topic)"
           if="$(eval arg('semantic_topic') not in ('', '/semantic/labels'))"/>
    <param name="semantic_input_type" value="$(arg semantic_input_type)"
           if="$(eval arg('semantic_input_type') != '')"/>
    <param name="depth_input_topic" value="$(arg depth_input_topic)"
           if="$(eval arg('depth_input_topic') not in ('', '/camera/depth/image_rect_raw'))"/>
    <param name="target_frame" value="$(arg target_frame)"
           if="$(eval arg('target_frame') != '')"/>
    <param name="projection_invalid_mask_topic" value="$(arg projection_invalid_mask_topic)"
           if="$(eval arg('projection_invalid_mask_topic') != '')"/>
    <param name="projection_invalid_mask_value" value="$(arg projection_invalid_mask_value)"
           if="$(eval arg('projection_invalid_mask_value') != '')"/>
    <param name="experiment_variant_name" value="$(arg experiment_variant_name)"
           if="$(eval arg('experiment_variant_name') != '')"/>
    <param name="bag_name" value="$(arg bag_name)"
           if="$(eval arg('bag_name') != '')"/>
    <param name="results_dir" value="$(arg results_dir)"
           if="$(eval arg('results_dir') != '')"/>
    <param name="enable_metrics_csv" value="$(arg enable_metrics_csv)"/>
    <!-- Gate overrides: <group> is invalid inside <node> in ROS1; use per-param if= instead. -->
    <param name="use_invalid_mask" value="$(arg use_invalid_mask)"
           if="$(eval arg('use_invalid_mask') != '')"/>
    <param name="use_depth_edge_rejection" value="$(arg use_depth_edge_rejection)"
           if="$(eval arg('use_depth_edge_rejection') != '')"/>
    <param name="use_occlusion_gate" value="$(arg use_occlusion_gate)"
           if="$(eval arg('use_occlusion_gate') != '')"/>
    <param name="projection_patch_size" value="$(arg projection_patch_size)"
           if="$(eval arg('projection_patch_size') != '')"/>
    <param name="projection_confidence_min" value="$(arg projection_confidence_min)"
           if="$(eval arg('projection_confidence_min') != '')"/>
    <param name="projection_reject_depth_edges" value="$(arg projection_reject_depth_edges)"
           if="$(eval arg('projection_reject_depth_edges') != '')"/>
    <param name="projection_occlusion_epsilon_m" value="$(arg projection_occlusion_epsilon_m)"
           if="$(eval arg('projection_occlusion_epsilon_m') != '')"/>
    <param name="projection_occlusion_radius_px" value="$(arg projection_occlusion_radius_px)"
           if="$(eval arg('projection_occlusion_radius_px') != '')"/>
    <param name="use_geometric_gate" value="$(arg use_geometric_gate)"
           if="$(eval arg('use_geometric_gate') != '')"/>
    <param name="projection_geometric_enable" value="$(arg projection_geometric_enable)"
           if="$(eval arg('projection_geometric_enable') != '')"/>
    <param name="geometric_curvature_max" value="$(arg geometric_curvature_max)"
           if="$(eval arg('geometric_curvature_max') != '')"/>
    <param name="geometric_up_labels" value="$(arg geometric_up_labels)"
           if="$(eval arg('geometric_up_labels') != '')"/>
    <param name="geometric_score_min" value="$(arg geometric_score_min)"
           if="$(eval arg('geometric_score_min') != '')"/>
    <param name="geometric_fold_into_confidence" value="$(arg geometric_fold_into_confidence)"
           if="$(eval arg('geometric_fold_into_confidence') != '')"/>
  </node>
</launch>
