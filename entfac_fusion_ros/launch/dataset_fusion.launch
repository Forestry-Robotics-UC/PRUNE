<launch>
  <arg name="use_sim_time" default="true"/>
  <arg name="use_urdf" default="true"/>
  <arg name="debug" default="false"/>
  <arg name="rviz" default="true"/>
  <arg name="rviz_config" default="$(find entfac_fusion_ros)/config/generic_main_topics.rviz"/>
  <arg name="urdf_path" default="$(find entfac_fusion_ros)/urdf/apparatus.urdf.xacro"/>
  <arg name="dataset_config" default="$(find entfac_fusion_ros)/config/dataset.yaml"/>
  <arg name="target_frame" default="base_link"/>
  <arg name="output_topic" default="/ouster/rgb_colored"/>
  <arg name="publish_localization_tf" default="false"/>
  <arg name="localization_topic" default="/localization_50hz"/>
  <arg name="localization_type" default="odom"/>
  <arg name="localization_parent_frame" default="odom"/>
  <arg name="localization_child_frame" default="$(arg target_frame)"/>
  <arg name="localization_stamp_source_topic" default=""/>
  <arg name="localization_stamp_source_type" default="image"/>
  <arg name="localization_stamp_source_max_age_sec" default="0.05"/>
  <arg name="run_mapir_index" default="false"/>
  <arg name="mapir_input_topic" default="/mapir/image_raw"/>
  <arg name="mapir_raw_topic" default="/mapir/indices/veg_index/image_raw"/>
  <arg name="mapir_preview_topic" default="/mapir/indices_color/veg_index"/>
  <arg name="mapir_filter_set" default="OCN"/>
  <arg name="mapir_nir_channel" default="-1"/>
  <arg name="mapir_visible_channel" default="-1"/>
  <arg name="mapir_colorize_min" default="0.20"/>
  <arg name="mapir_colorize_max" default="0.75"/>
  <arg name="run_ufomap" default="false"/>
  <arg name="ufomap_pkg" default="ufomap_mapping"/>
  <arg name="ufomap_depth_levels" default="16"/>
  <arg name="ufomap_num_workers" default="6"/>
  <arg name="ufomap_color" default="true"/>
  <arg name="ufomap_resolution" default="0.03"/>
  <arg name="ufomap_max_range" default="25.0"/>
  <arg name="ufomap_update_rate" default="20.0"/>
  <arg name="ufomap_pub_rate" default="5.0"/>

  <param name="use_sim_time" value="$(arg use_sim_time)"/>


  <group if="$(arg use_urdf)">
    <param name="robot_description" command="$(find xacro)/xacro --inorder '$(arg urdf_path)'" />
    <node pkg="robot_state_publisher"
          type="robot_state_publisher"
          name="robot_state_publisher"
          output="screen">
      <param name="publish_frequency" type="double" value="30.0"/>
    </node>
  </group>

  <group if="$(arg publish_localization_tf)">
    <node pkg="entfac_fusion_ros" type="pose_to_tf.py" name="localization_to_tf" output="screen">
      <param name="pose_topic" value="$(arg localization_topic)"/>
      <param name="input_type" value="$(arg localization_type)"/>
      <param name="parent_frame" value="$(arg localization_parent_frame)"/>
      <param name="child_frame" value="$(arg localization_child_frame)"/>
      <param name="stamp_source_topic" value="$(arg localization_stamp_source_topic)"/>
      <param name="stamp_source_type" value="$(arg localization_stamp_source_type)"/>
      <param name="stamp_source_max_age_sec" value="$(arg localization_stamp_source_max_age_sec)"/>
    </node>
  </group>

  <group if="$(arg run_mapir_index)">
    <node pkg="entfac_fusion_ros" type="mapir_index_node.py" name="mapir_index_node" output="screen">
      <param name="input_topic" value="$(arg mapir_input_topic)"/>
      <param name="raw_topic" value="$(arg mapir_raw_topic)"/>
      <param name="preview_topic" value="$(arg mapir_preview_topic)"/>
      <param name="filter_set" value="$(arg mapir_filter_set)"/>
      <param name="nir_channel" value="$(arg mapir_nir_channel)"/>
      <param name="visible_channel" value="$(arg mapir_visible_channel)"/>
      <param name="colorize_min" value="$(arg mapir_colorize_min)"/>
      <param name="colorize_max" value="$(arg mapir_colorize_max)"/>
    </node>
  </group>

  <rosparam command="load"
            file="$(find entfac_fusion_ros)/config/core.yaml"
            ns="colored_pcl_node"/>
  <rosparam command="load"
            file="$(find entfac_fusion_ros)/config/expert.yaml"
            ns="colored_pcl_node"/>
  <rosparam command="load"
            file="$(arg dataset_config)"
            ns="colored_pcl_node"/>
  <param name="colored_pcl_node/target_frame" value="$(arg target_frame)"/>

  <node pkg="entfac_fusion_ros" type="colored_pcl_node.py" name="colored_pcl_node"
        output="screen"
        args="$(eval '_debug:=' + str(arg('debug')).lower())">
    <remap from="semantic_pointcloud" to="$(arg output_topic)"/>
  </node>

  <group if="$(arg run_ufomap)">
    <node pkg="$(arg ufomap_pkg)" type="ufomap_mapping_server_node" name="ufomap_mapping_server_node" output="screen" required="true">
      <param name="resolution" value="$(arg ufomap_resolution)"/>
      <param name="depth_levels" value="$(arg ufomap_depth_levels)"/>
      <param name="num_workers" value="$(arg ufomap_num_workers)"/>
      <param name="color_map" value="$(arg ufomap_color)"/>
      <param name="max_range" value="$(arg ufomap_max_range)"/>
      <param name="update_rate" value="$(arg ufomap_update_rate)"/>
      <param name="pub_rate" value="$(arg ufomap_pub_rate)"/>
      <param name="verbose" value="True"/>
      <param name="transform_timeout" value="10"/>
      <remap from="cloud_in" to="$(arg output_topic)"/>
    </node>
  </group>

  <group if="$(arg rviz)">
    <node pkg="rviz" type="rviz" name="dataset_rviz"
          args="-d $(arg rviz_config)" output="screen"/>
  </group>
</launch>
